{
  "$schema": "https://enconvo.com/schemas/extension.json",
  "version": "0.0.37",
  "author": "EnconvoAI",
  "license": "MIT",
  "categories": [
    "File"
  ],
  "type": "module",
  "name": "exporter",
  "title": "Exporter",
  "description": "Export context messages to file.",
  "icon": "icon.png",
  "minAppVersion": "1.8.8",
  "commands": [
    {
      "name": "export_markdown",
      "title": "Save as Markdown",
      "description": "Export context messages to Markdown file.",
      "icon": "md.png",
      "mode": "no-view",
      "parameters": {
        "type": "object",
        "properties": {
          "user_input_text": {
            "type": "string",
            "description": "The user input text"
          },
          "input_text": {
            "type": "string",
            "description": "The input text"
          },
          "selection_text": {
            "type": "string",
            "description": "The selected text from current active application"
          }
        },
        "required": [
          "user_input_text"
        ]
      },
      "preferences": []
    }
  ],
  "dependencies": {
    "@enconvo/api": "link:/Users/ysnows/Documents/Project/enconvo.nodejs/enconvo_api"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "lint": "eslint src",
    "lint:fix": "npm run lint --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --list-different \"**/*.ts\"",
    "build": "enconvo",
    "dev": "enconvo --dev"
  }
}